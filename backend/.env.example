# BCI v3 — LLM configuration. Copy this file to `.env` and fill in what you have.
# Provider order (auto): local (Qwen) → NVIDIA NIM → OpenAI → Anthropic → OpenRouter → rule-based.
# Only set what you use. Real exported env vars override these. NEVER commit your real .env.

# --- Local LLM (Qwen via Ollama / vLLM / LM Studio) — the default, tried first ---
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3.5:9b
# LOCAL_LLM_KEY=            # only if your local server requires a bearer token

# Thinking models (Qwen3.5, DeepSeek-R1) reason before answering. The engine strips the reasoning
# and gives a generous token budget so the JSON isn't truncated. For faster, cleaner structured
# output, set this to skip the reasoning block entirely (appends /no_think to prompts):
# BCI_LLM_NO_THINK=1

# --- NVIDIA NIM (fallback) ---
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BCI_LLM_MODEL=qwen/qwen2.5-7b-instruct

# --- Cloud fallbacks (optional) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
