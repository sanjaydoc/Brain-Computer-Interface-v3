# BCI v3 — LLM configuration. Copy this file to `.env` and fill in what you have.
# Provider order (auto): local (Qwen) → NVIDIA NIM → OpenAI → Anthropic → OpenRouter → rule-based.
# Only set what you use. Real exported env vars override these. NEVER commit your real .env.

# --- Local LLM (Qwen via Ollama / vLLM / LM Studio) — the default, tried first ---
LOCAL_LLM_URL=http://localhost:11434/v1

# Pick ONE model as the default. Both can be installed in Ollama at once — swap which line is
# uncommented to change the default, or override per run with LOCAL_LLM_MODEL=... (see RUN.md 4b).
# Use the exact tag shown by `ollama list`.
LOCAL_LLM_MODEL=qwen3.5:9b          # thinking model — deeper, more creative, slower
# LOCAL_LLM_MODEL=qwen2.5:7b        # direct/instruct — faster, great for lens tournaments
# LOCAL_LLM_KEY=                    # only if your local server requires a bearer token

# Thinking models (Qwen3.5, DeepSeek-R1) reason before answering. The engine strips the reasoning
# and gives a generous token budget so the JSON isn't truncated. For faster, cleaner structured
# output, set this to skip the reasoning block entirely (appends /no_think to prompts):
# BCI_LLM_NO_THINK=1

# --- NVIDIA NIM (fallback) ---
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BCI_LLM_MODEL=qwen/qwen2.5-7b-instruct

# --- Cloud fallbacks (optional) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# --- Literature grounding (retrieval sources) ---
# Keyless by default (PubMed / arXiv / Wikipedia / PubChem / USPTO). These are optional:
# NCBI_API_KEY=                 # higher PubMed rate limits
# GITHUB_TOKEN=                 # higher GitHub search rate limits
# SEARXNG_URL=http://localhost:8080   # enables the SearXNG web-search source
# BCIV3_SEARCH_SOURCES=pubmed,arxiv,wikipedia   # narrow the sources (default: all)

# --- Database (local MongoDB Community) ---
# Every invention auto-saves (design + multi-domain detail + parts + score). If Mongo is down or
# pymongo isn't installed, it falls back to a JSONL file, so nothing is lost.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bciv3
# BCIV3_JSONL=inventions.jsonl      # fallback file path when Mongo is unavailable
